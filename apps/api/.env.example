ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://living:living@localhost:5432/living_nutrition
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-development
JWT_ISSUER=living-nutrition-api
JWT_AUDIENCE=living-nutrition-mobile
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30
IDENTITY_PROVIDER=local
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_JWKS_CACHE_SECONDS=900
# Comma-separated Clerk user IDs for server-side operational audit review.
# Required in production and never exposed to mobile clients.
ADMIN_CLERK_SUBJECTS=
LOCAL_ACCOUNT_MIGRATION_ENABLED=false
LOCAL_ACCOUNT_MIGRATION_DEADLINE=
ALLOW_DEV_AUTH=true
ALLOW_LEGACY_LOCAL_TOKENS=true
OPENAI_API_KEY=
# Set false for a no-cost preview to block camera and label AI before an image
# is stored or a billable provider request is made.
AI_FEATURES_ENABLED=true
USDA_API_KEY=DEMO_KEY
NUTRITION_PROVIDER_TIMEOUT_SECONDS=8
NUTRITION_PROVIDER_MAX_ATTEMPTS=3
NUTRITION_PROVIDER_RETRY_BACKOFF_SECONDS=0.2
NUTRITION_PROVIDER_MAX_RETRY_DELAY_SECONDS=2
# Local preview uses in-memory circuit state. Production requires redis so
# provider outage state is shared between API replicas.
NUTRITION_PROVIDER_CIRCUIT_BREAKER_BACKEND=memory
NUTRITION_PROVIDER_CIRCUIT_BREAKER_REDIS_KEY_PREFIX=living-nutrition:provider-circuit:v1
NUTRITION_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
NUTRITION_PROVIDER_CIRCUIT_BREAKER_RECOVERY_SECONDS=30
NUTRITION_PROVIDER_CIRCUIT_BREAKER_PROBE_LEASE_SECONDS=10
FOOD_SEARCH_CACHE_TTL_SECONDS=900
# Stale provider records remain available while a database-backed lease and
# jittered exponential backoff bounds provider refresh attempts.
FOOD_SOURCE_REFRESH_LEASE_SECONDS=30
FOOD_SOURCE_REFRESH_RETRY_BASE_SECONDS=60
FOOD_SOURCE_REFRESH_RETRY_MAX_SECONDS=3600
FOOD_SOURCE_REFRESH_RETRY_JITTER_RATIO=0.2
# The scheduled worker considers this many stale provider records each sweep.
# It shares the request-path lease/backoff and never refreshes user-created food.
FOOD_SOURCE_REFRESH_WORKER_POLL_SECONDS=900
FOOD_SOURCE_REFRESH_WORKER_BATCH_SIZE=25
# Replay completed retry-sensitive requests for up to one day. Pending paid
# requests are reclaimable after five minutes if the API process stops.
IDEMPOTENCY_PENDING_TTL_SECONDS=300
IDEMPOTENCY_RESPONSE_TTL_SECONDS=86400
AI_QUOTA_WINDOW_DAYS=30
AI_QUOTA_RESERVATION_TTL_SECONDS=600
AI_QUOTA_FREE_MEAL_ANALYSIS_LIMIT=20
AI_QUOTA_FREE_LABEL_ANALYSIS_LIMIT=10
AI_QUOTA_FREE_IMAGES_LIMIT=40
AI_QUOTA_FREE_CONCURRENT_LIMIT=1
AI_QUOTA_TRIAL_MEAL_ANALYSIS_LIMIT=60
AI_QUOTA_TRIAL_LABEL_ANALYSIS_LIMIT=30
AI_QUOTA_TRIAL_IMAGES_LIMIT=120
AI_QUOTA_TRIAL_CONCURRENT_LIMIT=2
AI_QUOTA_PAID_MEAL_ANALYSIS_LIMIT=300
AI_QUOTA_PAID_LABEL_ANALYSIS_LIMIT=100
AI_QUOTA_PAID_IMAGES_LIMIT=600
AI_QUOTA_PAID_CONCURRENT_LIMIT=3
AI_QUOTA_DISABLED_MEAL_ANALYSIS_LIMIT=0
AI_QUOTA_DISABLED_LABEL_ANALYSIS_LIMIT=0
AI_QUOTA_DISABLED_IMAGES_LIMIT=0
AI_QUOTA_DISABLED_CONCURRENT_LIMIT=0
IMAGE_STORAGE_BACKEND=local
IMAGE_STORAGE_LOCAL_ROOT=/tmp/living-nutrition-private-images
IMAGE_STORAGE_S3_BUCKET=
IMAGE_STORAGE_S3_PREFIX=living-nutrition
# Use `cloudflare_r2` with `auto` region and the account-specific HTTPS R2
# endpoint. Keep its access key and secret in managed environment settings.
IMAGE_STORAGE_S3_COMPATIBILITY=aws
IMAGE_STORAGE_S3_REGION=
IMAGE_STORAGE_S3_ENDPOINT_URL=
IMAGE_STORAGE_S3_KMS_KEY_ID=
IMAGE_STORAGE_S3_ACCESS_KEY_ID=
IMAGE_STORAGE_S3_SECRET_ACCESS_KEY=
IMAGE_RETENTION_WORKER_POLL_SECONDS=300
IMAGE_SIGNED_URL_SECONDS=300
# Required in production. Select this with the approved privacy/operations
# schedule; local preview leaves it unset and performs no audit-log purge.
AUDIT_LOG_RETENTION_DAYS=
# Production requires a managed HTTPS append-only receiver. The API signs only
# minimal audit envelopes; do not point this at a general-purpose public webhook.
AUDIT_DELIVERY_BACKEND=disabled
AUDIT_DELIVERY_WEBHOOK_URL=
AUDIT_DELIVERY_HMAC_SECRET=
AUDIT_DELIVERY_TIMEOUT_SECONDS=5
AUDIT_DELIVERY_LEASE_SECONDS=60
AUDIT_DELIVERY_RETRY_BASE_SECONDS=30
AUDIT_DELIVERY_RETRY_MAX_SECONDS=3600
ANALYSIS_JOB_LEASE_SECONDS=300
ANALYSIS_JOB_EXPIRY_HOURS=24
ANALYSIS_JOB_WORKER_POLL_SECONDS=3
RATE_LIMIT_ENABLED=true
# Use memory for local phone preview. Production requires redis.
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_KEY_PREFIX=living-nutrition:rate-limit:v1
# Comma-separated CIDRs for only the proxies allowed to set X-Forwarded-For.
# Production requires an explicit value selected for the deployed platform.
TRUSTED_PROXY_CIDRS=
RATE_LIMIT_AUTH_MAX_REQUESTS=12
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# Anonymous provider-catalog search budget. This is IP-scoped only because
# GET /foods/search is currently public; Redis hashes the derived key.
RATE_LIMIT_FOOD_SEARCH_MAX_REQUESTS=30
RATE_LIMIT_FOOD_SEARCH_WINDOW_SECONDS=60
RATE_LIMIT_ANALYSIS_MAX_REQUESTS=12
RATE_LIMIT_ANALYSIS_WINDOW_SECONDS=60
# Authenticated paid-analysis requests also use this independent per-user
# budget. Redis hashes the derived user key before persistence.
RATE_LIMIT_ANALYSIS_USER_MAX_REQUESTS=6
RATE_LIMIT_ANALYSIS_USER_WINDOW_SECONDS=60
# Prometheus-compatible metrics are disabled for local preview. Production
# requires both values and should scrape this endpoint over a private network.
METRICS_ENABLED=false
METRICS_BEARER_TOKEN=
# Optional in development; required in production. The API strips request
# bodies, user identity, device context, and breadcrumbs before Sentry sends.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
IMAGE_RETENTION_DAYS=30
